# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── TMDB ──────────────────────────────────────────────────────────────────────
TMDB_API_KEY=your-tmdb-v4-bearer-token

# ── Video Providers ───────────────────────────────────────────────────────────
NEXSTREAM_API_KEY=your-nexstream-key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: https://your-domain.vercel.app

# ── Admin ─────────────────────────────────────────────────────────────────────
# Comma-separated Supabase user UUIDs who have admin access
# Find your UUID: Supabase Dashboard → Authentication → Users
ADMIN_USER_IDS=

# ── Redis Cache (optional — falls back to in-memory if not set) ───────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
